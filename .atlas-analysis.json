{
  "projectType": "sdk-library",
  "projectName": "EZAnim",
  "projectDescription": "A Luau animation service module for Roblox that provides a clean API for playing, queuing, cross-fading, and managing character animations with support for ragdoll physics, state tracking, and motion tweening.",
  "theme": "sequoia",
  "primaryColor": "#848484",
  "lightColor": "#1a1a1a",
  "darkColor": "#cbcbcb",
